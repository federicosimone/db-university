--#1
SELECT * 
FROM university.students
WHERE `date_of_birth` >= '1990-01-01'
AND `date_of_birth` < '1991-01-01';

--#2
SELECT *
FROM university.courses
WHERE `cfu` > '10';

--#3
SELECT id, name, surname, date_of_birth, CURDATE()
FROM university.students
WHERE date_of_birth <= CURDATE() - INTERVAL 30 YEAR;

--#4
SELECT *
FROM university.courses
WHERE `period` = 'I semestre' 
AND `year` = '1';

--#5
SELECT * 
FROM university.exams
WHERE `hour` >= '14:00:00'
AND `date`= '2020-06-20';

--#6
SELECT * 
FROM university.degrees
WHERE `level` = 'magistrale';

--#7
SELECT COUNT(*) FROM `departments`;

--#8
SELECT COUNT(id) FROM `teachers`
WHERE `phone` IS NULL;

--BONUS GROUPBY

--#1
SELECT COUNT(id), YEAR(enrolment_date) AS anno
FROM university.students
GROUP BY YEAR(enrolment_date);

--#2
SELECT COUNT(id), office_address
FROM university.teachers
GROUP BY office_address;

--#3 
SELECT COUNT(exam_id),AVG(vote) 
FROM university.exam_student
GROUP BY exam_id;

--#4
SELECT count(id), department_id
FROM university.degrees
GROUP BY department_id;


